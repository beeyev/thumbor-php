{
    "name": "lostfocus/thumbor-php",
    "description": "Thumbor library for PHP",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Thumbor"
    ],
    "authors": [
        {
            "name": "Alexander Tebiev",
            "email": "alexander.tebiev@gmail.com",
            "homepage": "https://github.com/beeyev/"
        },
        {
            "name": "Dominik Schwind",
            "email": "dschwind@lostfocus.de",
            "homepage": "https://dominikschwind.com"
        }
    ],
    "homepage": "https://github.com/lostfocus/thumbor-php",
    "require": {
        "php": "^7.0 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^6 || ^7 || ^8 || ^9 || ^10",
        "rector/rector": "^2.4"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Beeyev\\Thumbor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beeyev\\Thumbor\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Thumbor": "Beeyev\\Thumbor\\Adapters\\Laravel\\Facades\\ThumborFacade"
            },
            "providers": [
                "Beeyev\\Thumbor\\Adapters\\Laravel\\ThumborServiceProvider"
            ]
        }
    }
}
